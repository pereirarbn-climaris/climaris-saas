POSTGRES_USER=erp_user
POSTGRES_PASSWORD=troque_essa_senha_forte
POSTGRES_DB=erp_db
DATABASE_URL=postgresql+psycopg://erp_user:troque_essa_senha_forte@db:5432/erp_db
JWT_SECRET_KEY=troque_chave_jwt_super_forte
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_BOOTSTRAP_TOKEN=troque_bootstrap_token
WORKDAY_START=08:00
WORKDAY_END=18:00
SCHEDULE_BUFFER_MINUTES=15
ENFORCE_EQUIPMENT_ON_SERVICE_ORDER=false
LOG_LEVEL=INFO
# Domínios do front + Evolution Manager (separados). O código já inclui app/evo.climaris.com.br como fallback.
CORS_ORIGINS=https://app.seudominio.com.br,https://evo.seudominio.com.br,https://climaris-erp.vercel.app
CORS_ORIGIN_REGEX=^https://.*\\.vercel\\.app$

# CNPJá — chave da API comercial (https://cnpja.com/api). Somente no servidor; usada em /api/v1/cnpj/commercial/... (ex.: dados completos para NF).
# Cadastro público usa a API open (sem chave). Deixe vazio se ainda não tiver conta CNPJá.
CNPJA_API_KEY=

# Opcional: URL base da BrasilAPI para fallback de CNPJ (padrão: https://brasilapi.com.br/api/cnpj/v1)
# BRASILAPI_CNPJ_BASE=

# Upload de logo da empresa (S3 AWS)
# Ex.: bucket só de imagens da app (não use o bucket de backups).
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
# Opcional para S3 compatível (MinIO, Cloudflare R2 etc.)
AWS_S3_ENDPOINT_URL=
# Opcional para servir por CDN/domínio customizado
AWS_S3_PUBLIC_BASE_URL=
AWS_S3_TENANT_LOGO_PREFIX=tenant-logos
# Imagens de produto (prefixo no bucket; URLs públicas para Mercado Livre)
AWS_S3_PRODUCT_IMAGE_PREFIX=product-images
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Mercado Livre — OAuth app (https://developers.mercadolibre.com.br/). Redirect URI deve coincidir com MERCADO_LIVRE_REDIRECT_URI ou APP_PUBLIC_URL + /app/integrations/mercado-livre/callback
MERCADO_LIVRE_CLIENT_ID=
MERCADO_LIVRE_CLIENT_SECRET=
# Opcional; padrão: APP_PUBLIC_URL + /app/integrations/mercado-livre/callback
# MERCADO_LIVRE_REDIRECT_URI=https://app.seudominio.com.br/app/integrations/mercado-livre/callback

# Confirmacao de e-mail (SMTP - ex.: Hostinger)
APP_PUBLIC_URL=https://app.seudominio.com.br
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USERNAME=no-reply@seudominio.com.br
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@seudominio.com.br
SMTP_FROM_NAME=Climaris
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false
SMTP_ALLOW_DB_OVERRIDE=false
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
VITE_API_URL=https://app.climaris.com.br
VITE_PLATFORM_OPERATOR_EMAIL=contato@climaris.com.br

# 2FA por e-mail no login de usuários admin. Só é exigido se LOGIN_ADMIN_TWO_FACTOR_ENABLED=true (padrão) e houver SMTP (SMTP_HOST ou credencial smtp no painel com SMTP_ALLOW_DB_OVERRIDE=true). Sem SMTP, o login de admin segue sem 2FA para não quebrar o acesso.
# LOGIN_ADMIN_TWO_FACTOR_ENABLED=false
# Dispositivo confiável: após 2FA, cookie HTTP-only (tabela login_trusted_devices) para pular 2FA no mesmo navegador até expirar.
# LOGIN_ADMIN_TRUST_DEVICE_ENABLED=true
# TRUST_DEVICE_DAYS=30
# TRUST_COOKIE_NAME=climaris_tf_trust
# TRUST_COOKIE_DOMAIN=
# TRUST_COOKIE_SECURE=

# Evolution API (WhatsApp) - MVP notificações
# URL que o *backend* usa para chamar a Evolution (criar instância, QR code, enviar texto).
# - Com `docker compose` deste repo: deixe vazio e use o override em docker-compose.yml
#   (`http://evolution_api:8080`) para evitar falha de DNS com o domínio público dentro do container.
# - API fora do Docker na mesma máquina: http://127.0.0.1:8080
# - Caso contrário: https://evo.seudominio.com
EVOLUTION_API_BASE_URL=
EVOLUTION_API_KEY=
# Opcional: origem HTTP nas chamadas à Evolution (padrão: APP_PUBLIC_URL). Necessário se CORS da Evolution não for *.
# EVOLUTION_CORS_REQUEST_ORIGIN=https://app.seudominio.com.br
EVOLUTION_INSTANCE=
#
# Webhook /api/v1/whatsapp/webhook/evolution — use UMA destas linhas de ação (não misture “string fixa” com expectativa de JWT no Manager):
#
# Opção A — token estático (no Manager: desative “Events as JWT” se existir; valor idêntico em ?token= ou header apikey / x-webhook-token)
# EVOLUTION_WEBHOOK_TOKEN=seu_token_fixo_igual_ao_manager
# EVOLUTION_WEBHOOK_JWT_USE_APIKEY=false
#
# Opção B — JWT assinado com a mesma chave global da Evolution (AUTHENTICATION_API_KEY)
# EVOLUTION_API_KEY=mesma_chave_que_AUTHENTICATION_API_KEY_no_evo
# EVOLUTION_WEBHOOK_JWT_USE_APIKEY=true
# EVOLUTION_WEBHOOK_TOKEN=   (deixe vazio no servidor; comente a linha antiga para não confundir)
#
# Outros JWT: EVOLUTION_WEBHOOK_JWT_SECRET = jwt_key do webhook na Evolution; ou JWT de sessão do ERP em ?token= (JWT_SECRET_KEY, expira).
EVOLUTION_WEBHOOK_TOKEN=
# Mesmo segredo que `jwt_key` na Evolution (HS256 em ?token= / Bearer), se não usar USE_APIKEY.
EVOLUTION_WEBHOOK_JWT_SECRET=
# true = validar JWT do webhook com EVOLUTION_API_KEY (Opção B).
EVOLUTION_WEBHOOK_JWT_USE_APIKEY=false
WHATSAPP_WEBHOOK_ENABLED=false
WHATSAPP_INTERACTIVE_BUTTONS_ENABLED=false
WHATSAPP_REMINDER_WORKER_ENABLED=true
WHATSAPP_REMINDER_WORKER_INTERVAL_SECONDS=60

# Anthropic Claude — respostas automáticas no WhatsApp (webhook Evolution → generate_ai_response).
# WHATSAPP_AI_INCOMING_ENABLED=true
# CLAUDE_API_KEY=
# CLAUDE_MODEL=claude-haiku-4-5-20251201

# Vercel env sync
VERCEL_PROJECT_ID=climaris-erp
VERCEL_TEAM_ID=
VERCEL_TOKEN=

# NFS-e nacional — opcional. Se definida, o backend envia o JSON interno da emissão em POST para esta URL.
# A resposta deve ser JSON com "authorized": true e, se emitida, "nfse_number", "verification_code" (homologação / gateway próprio).
# Sem gateway, o backend envia ao Sefin Nacional (host sefin.*): POST .../SefinNacional/nfse + JSON dpsXmlGZipB64 + mTLS (A1).
# O host adn.* é para consultas GET no ADN — não use para POST de emissão (costuma dar 404).
# NFSE_NACIONAL_GATEWAY_URL=
#
# --- Emissão (Sefin Nacional) ---
# NFSE_EMIT_BASE_URL_HOMOLOG=https://sefin.producaorestrita.nfse.gov.br
# NFSE_EMIT_BASE_URL_PROD=https://sefin.nfse.gov.br
#
# --- Consultas no ADN (GET DPS, etc.) ---
# NFSE_ADN_BASE_URL_HOMOLOG=https://adn.producaorestrita.nfse.gov.br
# NFSE_ADN_BASE_URL_PROD=https://adn.nfse.gov.br
#
# Legado (ainda suportado): só bases ADN — usadas apenas para GET / consultas.
# NFSE_SEFIN_BASE_URL=
# NFSE_SEFIN_BASE_URL_HOMOLOG=
#
# Margem (minutos) subtraída do relógio ao montar dhEmi/dCompet — reduz rejeição E0008 (emissão “no futuro”).
# Inteiro 0–45; padrão 20 (nota “no passado” para absorver NTP). Reduza se dhEmi ficar velho demais.
# NFSE_DPS_DH_EMI_SKEW_MINUTES=20
#
# Remover acentos em textos da DPS (tomador, discriminação, logradouro) — reduz E999/rejeições em alguns ambientes.
# 1 (padrão) ou 0 para enviar UTF-8 com diacríticos.
# NFSE_DPS_XML_ASCII_FOLD=1
#
# Validação XSD da DPS antes do POST ao Sefin (só ativa se existir ``Docs/nfse-xsd-extracted/Schemas/1.01/DPS_v1.01.xsd``).
# 0/false desliga. Pasta alternativa: NFSE_XSD_SCHEMA_ROOT=/caminho/para/Schemas/1.01
# NFSE_DPS_XSD_VALIDATE=1
# NFSE_XSD_SCHEMA_ROOT=
#
# Inscrição municipal do prestador (tag IM na DPS), até 15 caracteres — se exigida pelo município.
# Alternativa ao campo em Admin → NFS-e: definir só aqui em servidor.
# NFSE_PRESTADOR_INSCRICAO_MUNICIPAL=
#
# IE ativa (ex.: consulta CNPJá / Cadastro de Contribuintes) usada na tag ``<IM>`` quando o município na restrita
# exige identificação cadastral além do CNPJ (não confundir IE com IM no cadastro da Receita — é só fallback de valor).
# Ex.: NFSE_PRESTADOR_IE_PARA_TAG_IM=181820892112
# NFSE_PRESTADOR_IE_PARA_TAG_IM=
#
# Série da DPS (XML / Id). Emissão **por API** (este backend): use faixa de **integração/webservice** (orientação
# CGNFS-e, típico 00001–49999; ex. 900 ou 1). Série 70000–79999 costuma ser **só** na emissão pelo **site** do Portal
# — na API costuma dar **E0010**. Admin → NFS-e ou variável abaixo.
# NFSE_DPS_SERIE=900
#
# Telefone do prestador na tag ``<prest><fone>`` (só dígitos, ≥10). Sobrescreve o telefone da empresa em Admin.
# NFSE_DPS_PREST_FONE=
#
# Número da DPS no XML: compact (padrão, moderado), millis, nanos (antes), fixed + NFSE_DPS_NUMERO_FIXED.
# NFSE_DPS_NUMERO_MODE=compact
# NFSE_DPS_NUMERO_FIXED=200
#
# DPS <trib>: MEI não envia <tribFed> (E0676). MEI: só <totTrib><indTotTrib>0</indTotTrib> — não enviar pTotTribSN (E0710).
#
# Local da prestação / incidência → ``serv/locPrest/cLocPrestacao`` (não usar ``cMunicIncid`` em ``tribMun`` — E1235).
# Prioridade: NFSE_DPS_CLOC_PRESTACAO → NFSE_DPS_CMUNIC_INCID → IBGE do tomador → emitente.
# NFSE_DPS_CLOC_PRESTACAO=
# NFSE_DPS_CMUNIC_INCID=3503208
#
# Tag ``serie`` no XML com zeros à esquerda (00001). Para valor compacto (1): NFSE_DPS_SERIE_XML_SEM_PADDING=1
#
# Na DPS só há <vServ> em valores/vServPrest; vLiq existe na NFS-e autorizada (retorno), não no XML enviado.
#
# E0162: MEI e não optante não podem usar regApTribSN — a tag **não** é enviada para opSimpNac 1 ou 2.
# Só ME/EPP (3) e, se a NT exigir: NFSE_REG_AP_TRIB_SN_MEEPP=1 e opcional NFSE_REG_AP_TRIB_SN=1
# NFSE_REG_AP_TRIB_SN_MEEPP=
# NFSE_REG_AP_TRIB_SN=1
#
# Path do POST de emissão (referência pedrocasado/nfse-php):
# NFSE_SEFIN_EMIT_PATH=/SefinNacional/nfse
#
# GET acompanhamento da DPS no ADN — prefixo antes de /{idDPS}.
# NFSE_SEFIN_DPS_PATH=/dps
#
# GET consulta da NFS-e pela chave de acesso — template com {chaveAcesso}.
# NFSE_SEFIN_STATUS_PATH=/nfse/v1/nfse/{chaveAcesso}
#
# Desliga o POST direto ao ADN (útil em dev ou se só usar gateway). Com 1/true, volta a “Pendente envio”.
# NFSE_SEFIN_DISABLED=
#
# Logs de diagnóstico do POST (URL, tamanho do XML, presença de assinatura): defina 1/true.
# NFSE_SEFIN_DEBUG=
#
# Após POST da DPS, se a resposta ainda não trouxer NFS-e autorizada, o backend faz polling GET {NFSE_SEFIN_DPS_PATH}/{idDPS}.
# NFSE_SEFIN_POLL_MAX_ATTEMPTS=15
# NFSE_SEFIN_POLL_DELAY_SEC=2
# Primeiros GET 404 podem ser atraso de indexação no ADN (não encerra o polling de imediato).
# NFSE_SEFIN_POLL_404_SOFT_MAX=10
# NFSE_SEFIN_POLL_DISABLED=
#
# --- Focus NFe (NFSe Nacional via intermediário; POST /v2/nfsen) ---
# Token no Painel Focus (HTTP Basic: usuário = token, senha vazia). Preferir Admin → NFS-e.
# Polling após resposta assíncrona da Focus:
# NFSE_FOCUS_POLL_MAX_ATTEMPTS=18
# NFSE_FOCUS_POLL_DELAY_SEC=2
# NFSE_FOCUS_TRIBUTACAO_ISS=1
# NFSE_FOCUS_TIPO_RETENCAO_ISS=1
