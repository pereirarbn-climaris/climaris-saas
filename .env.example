POSTGRES_USER=erp_user
POSTGRES_PASSWORD=troque_essa_senha_forte
POSTGRES_DB=erp_db
DATABASE_URL=postgresql+psycopg://erp_user:troque_essa_senha_forte@db:5432/erp_db
JWT_SECRET_KEY=troque_chave_jwt_super_forte
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_BOOTSTRAP_TOKEN=troque_bootstrap_token
WORKDAY_START=08:00
WORKDAY_END=18:00
SCHEDULE_BUFFER_MINUTES=15
ENFORCE_EQUIPMENT_ON_SERVICE_ORDER=false
LOG_LEVEL=INFO
CORS_ORIGINS=https://app.seudominio.com.br,https://climaris-erp.vercel.app
CORS_ORIGIN_REGEX=^https://.*\\.vercel\\.app$

# CNPJá — chave da API comercial (https://cnpja.com/api). Somente no servidor; usada em /api/v1/cnpj/commercial/... (ex.: dados completos para NF).
# Cadastro público usa a API open (sem chave). Deixe vazio se ainda não tiver conta CNPJá.
CNPJA_API_KEY=

# Opcional: URL base da BrasilAPI para fallback de CNPJ (padrão: https://brasilapi.com.br/api/cnpj/v1)
# BRASILAPI_CNPJ_BASE=

# Upload de logo da empresa (S3 AWS)
# Ex.: bucket só de imagens da app (não use o bucket de backups).
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
# Opcional para S3 compatível (MinIO, Cloudflare R2 etc.)
AWS_S3_ENDPOINT_URL=
# Opcional para servir por CDN/domínio customizado
AWS_S3_PUBLIC_BASE_URL=
AWS_S3_TENANT_LOGO_PREFIX=tenant-logos
# Imagens de produto (prefixo no bucket; URLs públicas para Mercado Livre)
AWS_S3_PRODUCT_IMAGE_PREFIX=product-images
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Mercado Livre — OAuth app (https://developers.mercadolibre.com.br/). Redirect URI deve coincidir com MERCADO_LIVRE_REDIRECT_URI ou APP_PUBLIC_URL + /app/integrations/mercado-livre/callback
MERCADO_LIVRE_CLIENT_ID=
MERCADO_LIVRE_CLIENT_SECRET=
# Opcional; padrão: APP_PUBLIC_URL + /app/integrations/mercado-livre/callback
# MERCADO_LIVRE_REDIRECT_URI=https://app.seudominio.com.br/app/integrations/mercado-livre/callback

# Confirmacao de e-mail (SMTP - ex.: Hostinger)
APP_PUBLIC_URL=https://app.seudominio.com.br
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USERNAME=no-reply@seudominio.com.br
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@seudominio.com.br
SMTP_FROM_NAME=Climaris
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false
SMTP_ALLOW_DB_OVERRIDE=false
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
VITE_API_URL=https://app.climaris.com.br
VITE_PLATFORM_OPERATOR_EMAIL=contato@climaris.com.br

# 2FA por e-mail no login de usuários admin. Só é exigido se LOGIN_ADMIN_TWO_FACTOR_ENABLED=true (padrão) e houver SMTP (SMTP_HOST ou credencial smtp no painel com SMTP_ALLOW_DB_OVERRIDE=true). Sem SMTP, o login de admin segue sem 2FA para não quebrar o acesso.
# LOGIN_ADMIN_TWO_FACTOR_ENABLED=false

# Evolution API (WhatsApp) - MVP notificações
# URL que o *backend* usa para chamar a Evolution (criar instância, QR code, enviar texto).
# - Com `docker compose` deste repo: deixe vazio e use o override em docker-compose.yml
#   (`http://evolution_api:8080`) para evitar falha de DNS com o domínio público dentro do container.
# - API fora do Docker na mesma máquina: http://127.0.0.1:8080
# - Caso contrário: https://evo.seudominio.com
EVOLUTION_API_BASE_URL=
EVOLUTION_API_KEY=
# Opcional: origem HTTP nas chamadas à Evolution (padrão: APP_PUBLIC_URL). Necessário se CORS da Evolution não for *.
# EVOLUTION_CORS_REQUEST_ORIGIN=https://app.seudominio.com.br
EVOLUTION_INSTANCE=
# Token opcional para proteger webhook /api/v1/whatsapp/webhook/evolution
EVOLUTION_WEBHOOK_TOKEN=
WHATSAPP_WEBHOOK_ENABLED=false
WHATSAPP_INTERACTIVE_BUTTONS_ENABLED=false
WHATSAPP_REMINDER_WORKER_ENABLED=true
WHATSAPP_REMINDER_WORKER_INTERVAL_SECONDS=60

# Vercel env sync
VERCEL_PROJECT_ID=climaris-erp
VERCEL_TEAM_ID=
VERCEL_TOKEN=
