# Exemplo para copiar em `.env` na raiz (usado por `docker compose` para a API).
# Não commite o ficheiro `.env` real (está no .gitignore).

DATABASE_URL=postgresql+psycopg://erp_user:erp_password@db:5432/erp_db
JWT_SECRET_KEY=troque_em_producao

# Mesmo valor que AUTHENTICATION_API_KEY em deploy/evolution/.env
EVOLUTION_API_KEY=

APP_PUBLIC_URL=https://app.seudominio.com.br
EVOLUTION_CORS_REQUEST_ORIGIN=https://app.seudominio.com.br
