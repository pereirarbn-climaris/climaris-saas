# Produção no MESMO domínio do SPA (Nginx faz proxy de /api/v1): deixe vazio.
# Só defina se o front estiver em outro host (ex.: CDN) e a API em outro URL.
# VITE_API_URL=
#
# Exemplo API em outro origin:
# VITE_API_URL=https://api.climaris.com.br
#
# Opcional: mesmo valor que PLATFORM_OPERATOR_EMAIL no .env da API (e-mail operador / painel /operacao).
# VITE_PLATFORM_OPERATOR_EMAIL=contato@climaris.com.br
#
# Opcional para previews (v0/Vercel) sem backend acessivel:
# true / 1 / yes: o login NAO chama a API; grava o token de demo (igual ao botao "Entrar como Demo") e libera o SPA.
# NUNCA use em build de producao com dados reais.
# VITE_LOGIN_DEMO_ENABLED=true
