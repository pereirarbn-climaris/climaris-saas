# Exemplo de proxy para Evolution API + Manager
# Ajuste domínio e certificados antes de habilitar.

upstream evolution_api {
    server 127.0.0.1:8080;
    keepalive 8;
}

upstream evolution_manager {
    server 127.0.0.1:3001;
    keepalive 8;
}

server {
    listen 80;
    listen [::]:80;
    server_name evo.climaris.com.br manager-evo.climaris.com.br;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name evo.climaris.com.br;

    ssl_certificate     /etc/letsencrypt/live/evo.climaris.com.br/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/evo.climaris.com.br/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 20m;

    location / {
        proxy_pass http://evolution_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name manager-evo.climaris.com.br;

    ssl_certificate     /etc/letsencrypt/live/manager-evo.climaris.com.br/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/manager-evo.climaris.com.br/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        proxy_pass http://evolution_manager;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
