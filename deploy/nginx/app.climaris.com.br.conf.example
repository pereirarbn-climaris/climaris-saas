# Exemplo para app.climaris.com.br — copie para sites-available e ajuste paths SSL (Certbot costuma preencher).
# Depois: sudo nginx -t && sudo systemctl reload nginx
#
# UPSTREAM: API FastAPI (Docker) em 127.0.0.1:8000
# STATIC:  npm run build em frontend/dist → copiar para /var/www/climaris-web (veja scripts/deploy-frontend.sh)

upstream climaris_api {
    server 127.0.0.1:8000;
    keepalive 8;
}

# Redirecionar HTTP → HTTPS (ajuste se Certbot já geriu este bloco)
server {
    listen 80;
    listen [::]:80;
    server_name app.climaris.com.br;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name app.climaris.com.br;

    # Certbot / Let's Encrypt
    ssl_certificate     /etc/letsencrypt/live/app.climaris.com.br/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/app.climaris.com.br/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    root /var/www/climaris-web;
    index index.html;
    # Evita 413 em uploads (logo da empresa, anexos futuros).
    client_max_body_size 10m;

    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml;

    # Webhook Evolution: pode demorar (IA / DB); evita "upstream prematurely closed" no Nginx.
    location ^~ /api/v1/whatsapp/webhook/evolution {
        proxy_pass http://climaris_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 120s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;
        proxy_buffering off;
    }

    location /api/ {
        proxy_pass http://climaris_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    location = /health {
        proxy_pass http://climaris_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # URL colada errada — repassa à API, que redireciona para /health
    location = /healths.com.br/health {
        proxy_pass http://climaris_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Documentação OpenAPI (mesmo host que o SPA)
    location /docs {
        proxy_pass http://climaris_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /redoc {
        proxy_pass http://climaris_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /openapi.json {
        proxy_pass http://climaris_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Legado: assets estáticos antigos ainda servidos pela API (opcional)
    location /web/ {
        proxy_pass http://climaris_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # SPA React (Vite): rotas client-side caem no index.html
    location / {
        try_files $uri $uri/ /index.html;
    }
}
