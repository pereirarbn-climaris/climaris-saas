# URL publica da Evolution API
SERVER_URL=https://evo.seudominio.com

# Chave global da Evolution (use valor forte)
AUTHENTICATION_API_KEY=troque_por_chave_forte

# Banco interno da Evolution
POSTGRES_DATABASE=evolution
POSTGRES_USERNAME=evolution
POSTGRES_PASSWORD=troque_postgres_forte
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:troque_postgres_forte@evolution-postgres:5432/evolution?schema=public

# Redis interno da Evolution
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://evolution-redis:6379/6
CACHE_REDIS_PREFIX_KEY=evolution

# Recomendado para persistir estado das instancias no banco
CACHE_REDIS_SAVE_INSTANCES=false
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true

# Webhook global opcional (pode ser configurado por instancia tambem)
WEBHOOK_GLOBAL_ENABLED=false
WEBHOOK_GLOBAL_URL=

# CORS e porta (use * ou lista separada por vírgulas; não use JSON ["..."])
SERVER_TYPE=http
SERVER_PORT=8080
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_CREDENTIALS=true

# --- IA no WhatsApp (duas formas) ---
# (A) Motor Claude no backend Climaris: webhook global acima + no .env da API:
#     WHATSAPP_AI_INCOMING_ENABLED=true, CLAUDE_API_KEY, EVOLUTION_* — não precisa OPENAI na Evolution.
# (B) Bot OpenAI nativo da Evolution: OPENAI_ENABLED=true e credenciais via API
#     https://doc.evolution-api.com/v2/en/integrations/openai
