# Copie para /etc/system-backup/backup.env e ajuste (chmod 600):
#   sudo install -d -m 700 /etc/system-backup
#   sudo cp backup.env.example /etc/system-backup/backup.env
#   sudo chmod 600 /etc/system-backup/backup.env
#   sudo nano /etc/system-backup/backup.env
#
# ---------------------------------------------------------------------------
# Repositório restic no S3 (use bucket DEDICADO a backups, separado de assets web)
# Formato: s3.s3.<região>.amazonaws.com/nome-bucket/caminho-no-bucket
# O bucket TEM de existir na AWS (Console → S3 → Create bucket). Nome: só minúsculas, números e hífens, globalmente único.
# O caminho após / (ex. restic-repo) pode ser qualquer prefixo vazio dentro do bucket — o restic cria os ficheiros lá.
# Exemplo real (substitua pelo SEU bucket):
#   RESTIC_REPOSITORY=s3:climaris-backups-prod/restic-repo
#   AWS_DEFAULT_REGION=us-east-1
RESTIC_REPOSITORY=s3:SUBSTITUA-nome-real-do-bucket/restic-repo
#
# Obrigatório: palavra-passe FORTE e única (NÃO reutilize senhas de app).
# Se perder, o backup fica inacessível. Guarde em gestor de segredos.
RESTIC_PASSWORD=

# Região do bucket
AWS_DEFAULT_REGION=us-east-1

# Chaves IAM (permissão mínima: s3 no bucket de backup apenas; idealmente chave separada)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Diretório do projeto (docker-compose, .env)
PROJECT_ROOT=/root/.ssh

# (Opcional) Categorias: separa snapshots para políticas de retenção no prune
BACKUP_TAG_PREFIX=climaris-prod

# 02-verify-restore: leitura amostral (0 = só check estrutural, mais leve; ex.: 1 = 1%)
READ_DATA_CHECK_PERCENT=0

# 03-deep-check (domingos %): percentagem a ler no repositório (3 = 3%)
DEEP_CHECK_READ_DATA_PERCENT=3

# Cache local restic
RESTIC_CACHE_DIR=/var/cache/restic

# Staging de dumps (incluído no snapshot; não conter segredos extra além do que já vão no restic)
BACKUP_STAGING_DIR=/var/lib/system-backup/staging
